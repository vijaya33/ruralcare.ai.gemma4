@page "/"

<PageTitle>RuralCare AI</PageTitle>

<div class="container py-4">
    <div class="p-4 p-md-5 mb-4 bg-light border rounded-3 shadow-sm">
        <h1 class="display-5 fw-bold">RuralCare AI</h1>
        <p class="lead">
            Offline-first multimodal healthcare intelligence powered by Gemma 4.
        </p>
        <p>
            RuralCare AI helps healthcare workers in low-connectivity and underserved communities
            perform patient intake, triage symptom severity, summarize referral information,
            and generate structured clinical notes with explainable AI support.
        </p>
        <a class="btn btn-primary btn-lg" href="/intake">Start Patient Intake</a>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h4 class="card-title">Patient Intake</h4>
                    <p class="card-text">
                        Capture multilingual symptoms, demographic details, and field observations.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h4 class="card-title">AI Triage</h4>
                    <p class="card-text">
                        Generate risk-aware triage guidance, SOAP notes, and escalation recommendations.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h4 class="card-title">Offline-Ready Workflows</h4>
                    <p class="card-text">
                        Support remote clinics and mobile care teams with edge-capable AI workflows.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
